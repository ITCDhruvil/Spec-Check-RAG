# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# Database
# URL-encode special chars in password (@ → %40, # → %23, etc.)
DATABASE_URL=postgres://postgres:your_password@localhost:5432/spec_check_rag

# CORS (comma-separated in production via env list parsing)
CORS_ALLOWED_ORIGINS=http://localhost:3010,http://127.0.0.1:3010

# Admin account (user management access)
ADMIN_EMAIL=admin@itcube.net

# Media
MEDIA_ROOT=./media

# DOCX preview (Word-like layout via PDF). LibreOffice OR docx2pdf (Windows + Word).
DOCX_PREVIEW_ENABLED=True
# Example: C:\Program Files\LibreOffice\program\soffice.exe
LIBREOFFICE_PATH=
# Set True on Windows when Microsoft Word is installed (uses docx2pdf).
DOCX_PREVIEW_USE_WORD=False
DOCX_PREVIEW_TIMEOUT_SEC=120

# Upload limits
MAX_UPLOAD_SIZE_MB=50
API_THROTTLE_RATE=100/hour
UPLOAD_THROTTLE_RATE=30/hour

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_MAX_RETRIES=3
CELERY_TASK_RETRY_DELAY=60

# Logging
LOG_LEVEL=INFO

# Parsing (Phase 2) — requires Tesseract OCR binary on PATH for scanned PDF fallback
PARSING_OCR_ENABLED=True
PARSING_QUALITY_OCR_THRESHOLD=0.35
PARSING_MIN_PAGE_TEXT_LENGTH=25
PARSING_PDF_PARSER=auto

# AI provider: openai | azure
AI_PROVIDER=openai

# Azure OpenAI (when AI_PROVIDER=azure — OPENAI_MODEL = deployment name)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Azure deployment names (required when AI_PROVIDER=azure if names differ from model IDs)
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_CHAT_DEPLOYMENT_FAST=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# Azure Document Intelligence (layout parsing)
AZURE_DI_ENDPOINT=
AZURE_DI_KEY=
AZURE_DI_MODEL=prebuilt-layout

# Azure AI Search (Phase 3+ — set AZURE_SEARCH_RAG_ENABLED=true to use instead of Chroma)
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX_NAME=speccheck-chunks
AZURE_SEARCH_RAG_ENABLED=false

# OpenAI (Phase 3)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_FAST=gpt-4.1-mini
INTELLIGENCE_MODEL_ROUTING_ENABLED=true
INTELLIGENCE_MODEL_ESCALATION_ENABLED=true
INTELLIGENCE_HYBRID_RETRIEVAL_ENABLED=true
INTELLIGENCE_EXTRACTION_RETRIEVAL_TOP_K=12
INTELLIGENCE_EXTRACTION_MIN_RETRIEVAL_SCORE=0.18
INTELLIGENCE_ADAPTIVE_LEXICON_ENABLED=true
INTELLIGENCE_ADAPTIVE_LEXICON_LLM=true
INTELLIGENCE_ADAPTIVE_RETRY_ON_EMPTY=true
INTELLIGENCE_LEARNED_LEXICON_ENABLED=true
INTELLIGENCE_LEARNED_LEXICON_MIN_TERMS_PER_TYPE=8
INTELLIGENCE_ADAPTIVE_LLM_SKIP_IF_CACHE_FULL=true
OPENAI_TIMEOUT_SECONDS=120
OPENAI_MAX_RETRIES=3
OPENAI_TEMPERATURE=0.1
INTELLIGENCE_MAX_CHUNK_CHARS=6000
INTELLIGENCE_LEAF_CHUNK_CHARS=4800
INTELLIGENCE_CHUNK_OVERLAP_RATIO=0.10
INTELLIGENCE_COVER_PAGE_MAX=2
OPENAI_EMBEDDING_MAX_CHARS=10000
INTELLIGENCE_PROMPT_VERSION=4.4.1
# Dev: True = regenerate runs in Django (no Celery). False = requires celery worker -P solo
INTELLIGENCE_SYNC_GENERATION=True
# Parallel threads for extraction stage (1 per type, max 8). Reduce if hitting rate limits.
INTELLIGENCE_EXTRACTION_WORKERS=8
# Opt #5 — max chars per chunk after paragraph pre-filtering (3500 ≈ 875 tokens).
INTELLIGENCE_CHUNK_TRIM_CHARS=3500
# Opt #6 — chunks per LLM call (3 = default). Set to 1 to disable batching.
INTELLIGENCE_EXTRACTION_BATCH_SIZE=3
# Parse PDFs in a background thread (no Celery). Use True on Windows dev.
PROCESSING_SYNC=True

# Phase 4 — Chroma RAG chat (document-scoped)
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=spec_check_document_chunks
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
CHAT_RETRIEVAL_TOP_K=8
CHAT_MAX_HISTORY_TURNS=6
CHAT_MIN_RETRIEVAL_SCORE=0.25

# Production only
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
